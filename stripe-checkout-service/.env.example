# Stripe secret key
# For WireMock Cloud: any sk_test_... string works (key is not validated by WMC)
# For live Stripe sandbox: use your real sk_test_... key
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe API host override
# Leave all three unset to target api.stripe.com directly
# Set all three to redirect the Stripe SDK to a WireMock Cloud mock API
STRIPE_API_HOST=
STRIPE_API_PROTOCOL=
STRIPE_API_PORT=
